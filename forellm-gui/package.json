{
  "name": "forellm-gui",
  "version": "0.1.0",
  "description": "ForeLLM — Visual LLM Hardware Fitting Dashboard",
  "author": "Emir Lima",
  "license": "MIT",
  "main": "out/main/main.js",
  "productName": "ForeLLM",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "agent": "tsx cli/agent-cli.ts",
    "clean:release": "node -e \"try { require('fs').rmSync('release-build', { recursive: true, force: true }) } catch (e) {}\"",
    "dist": "npm run build && npm run clean:release && npx electron-builder",
    "dist:no-binary": "npm run build && npm run clean:release && npx electron-builder",
    "pre-dist": "cd .. && cargo build --release"
  },
  "build": {
    "appId": "com.emireln.forellm",
    "productName": "ForeLLM",
    "directories": {
      "output": "release-build"
    },
    "files": ["out/**/*"],
    "extraResources": [
      { "from": "../target/release", "to": ".", "filter": ["forellm.exe", "forellm"] }
    ],
    "win": {
      "icon": "../assets/forellm.ico",
      "executableName": "ForeLLM",
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "../assets/forellm.ico",
      "uninstallerIcon": "../assets/forellm.ico"
    }
  },
  "dependencies": {
    "@types/react-syntax-highlighter": "^15.5.13",
    "clsx": "^2.1.1",
    "lucide-react": "^0.510.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "electron-builder": "^25.0.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "electron": "^35.0.0",
    "electron-vite": "^3.1.0",
    "postcss": "^8.5.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
